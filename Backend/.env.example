# ─── App ────────────────────────────────────────────────
APP_NAME=Disaster Relief Backend
APP_ENV=development
DEBUG=true

# ─── Database ───────────────────────────────────────────
# Local Homebrew macOS (no password): postgresql+asyncpg://<your-os-username>@localhost:5432/disaster_relief
# Local Docker/Linux:                 postgresql+asyncpg://postgres:password@localhost:5432/disaster_relief
# Railway (Production):               Copy from Railway Postgres variables (add +asyncpg to the scheme)
DATABASE_URL=postgresql+asyncpg://pulkitverma@localhost:5432/disaster_relief
SYNC_DATABASE_URL=postgresql://pulkitverma@localhost:5432/disaster_relief


# ─── Security ───────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Twilio (SMS) ───────────────────────────────────────
# Leave blank to use mock mode (logs to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── WhatsApp Business API (via Twilio) ─────────────────
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
